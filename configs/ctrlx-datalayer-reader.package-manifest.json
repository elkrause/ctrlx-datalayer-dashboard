{
  "$schema": "https://json-schema.boschrexroth.com/ctrlx-automation/ctrlx-core/apps/package-manifest/package-manifest.v1.6.schema.json",
  "version": "1.0.0",
  "id": "ctrlx-datalayer-reader",

  "services": {
    "proxyMapping": [
      {
        "name": "ctrlx-datalayer-reader.web",
        "url": "/ctrlx-datalayer-reader",
        "binding": "unix://{$SNAP_DATA}/package-run/ctrlx-datalayer-reader/web.sock"
      }
    ]
  },

  "menus": {
    "sidebar": [
      {
        "id": "ctrlx-datalayer-reader-sidebar",
        "title": "Data Layer Dashboard",
        "icon": "bosch-ic-monitoring",
        "link": "/ctrlx-datalayer-reader",
        "target": "_blank"
      }
    ],
    "overview": [
      {
        "id": "ctrlx-datalayer-reader",
        "title": "Michaels ctrlX Data Layer Dashboard",
        "icon": "bosch-ic-monitoring",
        "link": "/ctrlx-datalayer-reader"
      }
    ]
  }
}
