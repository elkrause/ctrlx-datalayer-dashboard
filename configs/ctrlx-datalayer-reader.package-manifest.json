{
  "$schema": "https://json-schema.boschrexroth.com/ctrlx-automation/ctrlx-core/apps/package-manifest/package-manifest.v1.3.schema.json",
  "version": "1.0.0",
  "id": "ctrlx-datalayer-reader",

  "menus": {
    "sidebar": [
      {
        "id": "ctrlx-datalayer-reader",
        "title": "Data Layer Reader",
        "icon": "bosch-ic-monitoring",
        "permissions": [],
        "items": [
          {
            "id": "ctrlx-datalayer-reader-dashboard",
            "title": "Dashboard",
            "link": "/ctrlx-datalayer-reader",
            "permissions": []
          }
        ]
      }
    ]
  },

  "proxyMapping": [
    {
      "name": "ctrlx-datalayer-reader.web",
      "url": "/ctrlx-datalayer-reader",
      "binding": "unix://{$SNAP_DATA}/package-run/ctrlx-datalayer-reader/web.sock",
      "restricted": ["/ctrlx-datalayer-reader"]
    }
  ]
}
